---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductCard from "../../components/ProductCard.astro";
import { allProducts, productCopy, whatsappUrl } from "../../lib/products";
import { series } from "../../config";

const featured = allProducts.filter((product) => product.featured);
const heroProduct = allProducts.find((product) => product.slug === "pro-45l-cooler-wheeled-latch-version") || featured[0];
const heroCopy = productCopy(heroProduct, "zh");
const seriesCards = series.map((item) => ({
  ...item,
  product: featured.find((product) => product.series === item.key) || allProducts.find((product) => product.series === item.key),
  count: allProducts.filter((product) => product.series === item.key).length
}));
---

<BaseLayout locale="zh" title="LONFRO | 全球保温箱制造商" description="面向全球经销商、采购团队和自有品牌项目的保温箱批发与 OEM/ODM 制造服务。">
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy reveal">
        <p class="eyebrow">全球保温箱制造</p>
        <h1>为全球渠道而生的专业保温箱。</h1>
        <p class="hero-lead">公开批发参考价、真实产品规格，并为全球采购商提供灵活的 OEM/ODM 支持。</p>
        <div class="hero-actions">
          <a class="button button-primary" href="/zh/products/">浏览全部产品</a>
          <a class="button button-secondary" href={whatsappUrl("", "", "zh")} data-track="whatsapp_click">WhatsApp 咨询</a>
        </div>
      </div>
      <div class="hero-visual reveal reveal-delay">
        <div class="hero-media">
          <img src={heroProduct.image} width="900" height="900" alt={heroCopy.title} loading="eager" />
        </div>
        <div class="hero-product-note">
          <span>{heroCopy.seriesName}</span>
          <strong>{heroCopy.title}</strong>
          <a href={`/zh/products/${heroProduct.slug}/`}>查看详细规格</a>
        </div>
      </div>
    </div>
  </section>

  <section class="proof-strip" aria-label="制造实力概览">
    <div class="container proof-grid">
      <div><strong>100,000+ m²</strong><span>生产建筑面积</span></div>
      <div><strong>4,000,000+</strong><span>年产能</span></div>
      <div><strong>30+ 个国家</strong><span>全球市场覆盖</span></div>
      <div><strong>23+ 年</strong><span>制冷行业经验</span></div>
    </div>
  </section>

  <section class="section series-section">
    <div class="container">
      <div class="section-heading">
        <h2>五大产品系列</h2>
        <p>从便携小容量到大容量拉杆款，每个系列均可用于批发采购与自有品牌项目。</p>
      </div>
      <div class="series-grid">
        {seriesCards.map((item, index) => (
          <a class:list={["series-card", index < 2 && "series-card-large"]} href={`/zh/series/${item.key}/`}>
            <div class="series-image"><img src={item.product?.image} alt={item.nameZh} width="900" height="900" loading="lazy" /></div>
            <div class="series-copy">
              <span>{item.count} 款产品</span>
              <h3>{item.nameZh}</h3>
              <p>{item.blurbZh}</p>
              <strong>查看系列</strong>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section featured-section">
    <div class="container">
      <div class="section-heading compact-heading">
        <h2>代表产品</h2>
        <p>从每个系列选出一款代表型号，完整阶梯价格可在产品详情页查看。</p>
      </div>
      <div class="featured-products">
        {featured.map((product) => <ProductCard product={product} locale="zh" />)}
      </div>
      <div class="center-action"><a class="button button-secondary" href="/zh/products/">查看全部 62 款产品</a></div>
    </div>
  </section>

  <section class="section oem-section">
    <div class="container oem-grid">
      <div class="oem-copy">
        <h2>围绕您的市场需求定制。</h2>
        <p>通过颜色、包装、Logo 工艺和产品规格配置，开发属于您品牌的保温箱产品方案。</p>
        <a class="button button-primary" href="/zh/oem-odm/">了解 OEM / ODM</a>
      </div>
      <div class="capability-grid">
        <article><strong>产品设计</strong><p>从概念评审到结构、工艺和模具决策的全流程支持。</p></article>
        <article><strong>一体化生产</strong><p>覆盖吹塑、注塑、滚塑与发泡等制造工序。</p></article>
        <article><strong>质量验证</strong><p>提供实验室测试、生产检验和冷链验证支持。</p></article>
        <article><strong>全球交付规划</strong><p>提供纸箱、装柜和订单数量数据，便于采购评估。</p></article>
      </div>
    </div>
  </section>

  <section class="section manufacturing-section">
    <div class="container manufacturing-grid">
      <div class="manufacturing-visual">
        <img src={featured.find((product) => product.series === "outdoor")?.image} alt="LONFRO 户外拉杆保温箱" width="900" height="900" loading="lazy" />
      </div>
      <div class="manufacturing-copy">
        <p class="eyebrow">制造深度</p>
        <h2>从工程开发到成品包装。</h2>
        <p>广东冰能科技有限公司拥有现代化生产基地、专业实验室、智能生产线与端到端制造能力。</p>
        <div class="certification-line">
          <span>FCC</span><span>BSCI</span><span>CE</span><span>KC</span><span>SGS</span>
        </div>
        <a class="text-link" href="/zh/about/">了解制造企业</a>
      </div>
    </div>
  </section>

  <section class="section final-cta">
    <div class="container final-cta-inner">
      <div>
        <h2>发送目标型号和采购数量。</h2>
        <p>我们将在正式报价中确认价格、交期、定制范围和运输细节。</p>
      </div>
      <div class="hero-actions">
        <a class="button button-primary" href={whatsappUrl("", "", "zh")} data-track="whatsapp_click">WhatsApp 咨询</a>
        <a class="button button-secondary" href="/zh/contact/">申请报价</a>
      </div>
    </div>
  </section>
</BaseLayout>

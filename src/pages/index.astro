---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductCard from "../components/ProductCard.astro";
import { allProducts, whatsappUrl } from "../lib/products";
import { series } from "../config";

const featured = allProducts.filter((product) => product.featured);
const heroProduct = allProducts.find((product) => product.slug === "pro-45l-cooler-wheeled-latch-version") || featured[0];
const seriesCards = series.map((item) => ({
  ...item,
  product: featured.find((product) => product.series === item.key) || allProducts.find((product) => product.series === item.key),
  count: allProducts.filter((product) => product.series === item.key).length
}));
---

<BaseLayout>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy reveal">
        <p class="eyebrow">Global cooler manufacturing</p>
        <h1>Coolers built for distribution.</h1>
        <p class="hero-lead">Wholesale reference pricing, real product specifications and flexible OEM/ODM support for global buyers.</p>
        <div class="hero-actions">
          <a class="button button-primary" href="/products/">Browse All Products</a>
          <a class="button button-secondary" href={whatsappUrl()} data-track="whatsapp_click">Chat on WhatsApp</a>
        </div>
      </div>
      <div class="hero-visual reveal reveal-delay">
        <div class="hero-media">
          <img src={heroProduct.image} width="900" height="900" alt={heroProduct.title} loading="eager" />
        </div>
        <div class="hero-product-note">
          <span>{heroProduct.seriesName}</span>
          <strong>{heroProduct.title}</strong>
          <a href={`/products/${heroProduct.slug}/`}>View specifications</a>
        </div>
      </div>
    </div>
  </section>

  <section class="proof-strip" aria-label="Manufacturing highlights">
    <div class="container proof-grid">
      <div><strong>100,000+ m²</strong><span>Production buildings</span></div>
      <div><strong>4,000,000+</strong><span>Annual unit capacity</span></div>
      <div><strong>30+ countries</strong><span>Global market reach</span></div>
      <div><strong>23+ years</strong><span>Cooling industry experience</span></div>
    </div>
  </section>

  <section class="section series-section">
    <div class="container">
      <div class="section-heading">
        <h2>Five focused product families</h2>
        <p>From compact carriers to wheeled high-capacity coolers, each series is available for wholesale and private-label programs.</p>
      </div>
      <div class="series-grid">
        {seriesCards.map((item, index) => (
          <a class:list={["series-card", index < 2 && "series-card-large"]} href={`/series/${item.key}/`}>
            <div class="series-image"><img src={item.product?.image} alt={item.name} width="900" height="900" loading="lazy" /></div>
            <div class="series-copy">
              <span>{item.count} products</span>
              <h3>{item.name}</h3>
              <p>{item.blurb}</p>
              <strong>Explore series</strong>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section featured-section">
    <div class="container">
      <div class="section-heading compact-heading">
        <h2>Representative models</h2>
        <p>One selected product from each series. Full tier pricing is shown on every product detail page.</p>
      </div>
      <div class="featured-products">
        {featured.map((product) => <ProductCard product={product} />)}
      </div>
      <div class="center-action"><a class="button button-secondary" href="/products/">View all 62 products</a></div>
    </div>
  </section>

  <section class="section oem-section">
    <div class="container oem-grid">
      <div class="oem-copy">
        <h2>Built around your market.</h2>
        <p>Develop branded cooler programs with configurable color, packaging, logo treatment and product specifications.</p>
        <a class="button button-primary" href="/oem-odm/">Explore OEM / ODM</a>
      </div>
      <div class="capability-grid">
        <article><strong>Product design</strong><p>Support from concept review through structure and tooling decisions.</p></article>
        <article><strong>Integrated production</strong><p>Blow molding, injection molding, rotational molding and foam lines.</p></article>
        <article><strong>Quality verification</strong><p>Laboratory testing, production inspection and cold-chain validation support.</p></article>
        <article><strong>Global delivery planning</strong><p>Carton, container and order-volume data ready for procurement review.</p></article>
      </div>
    </div>
  </section>

  <section class="section manufacturing-section">
    <div class="container manufacturing-grid">
      <div class="manufacturing-visual">
        <img src={featured.find((product) => product.series === "outdoor")?.image} alt="LONFRO wheeled outdoor cooler" width="900" height="900" loading="lazy" />
      </div>
      <div class="manufacturing-copy">
        <p class="eyebrow">Manufacturing depth</p>
        <h2>From engineering to packed goods.</h2>
        <p>Guangdong Ice Energy Technology Co., Ltd. operates a modern production campus with professional laboratories, intelligent production lines and end-to-end manufacturing capabilities.</p>
        <div class="certification-line">
          <span>FCC</span><span>BSCI</span><span>CE</span><span>KC</span><span>SGS</span>
        </div>
        <a class="text-link" href="/about/">Learn about the manufacturer</a>
      </div>
    </div>
  </section>

  <section class="section final-cta">
    <div class="container final-cta-inner">
      <div>
        <h2>Send your target model and quantity.</h2>
        <p>We will confirm pricing, lead time, customization scope and shipping details in a formal quotation.</p>
      </div>
      <div class="hero-actions">
        <a class="button button-primary" href={whatsappUrl()} data-track="whatsapp_click">Chat on WhatsApp</a>
        <a class="button button-secondary" href="/contact/">Request a Quote</a>
      </div>
    </div>
  </section>
</BaseLayout>

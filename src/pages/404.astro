---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found | LONFRO">
  <section class="page-hero not-found">
    <div class="container narrow-heading">
      <h1>Page not found.</h1>
      <p>The product or page may have moved. Browse the current catalog or contact us for help.</p>
      <div class="hero-actions"><a class="button button-primary" href="/products/">Browse Products</a><a class="button button-secondary" href="/contact/">Contact Us</a></div>
    </div>
  </section>
</BaseLayout>

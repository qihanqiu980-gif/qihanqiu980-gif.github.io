---
interface Props { title: string; intro: string; }
const { title, intro } = Astro.props;
---

<section class="page-hero legal-hero">
  <div class="container narrow-heading">
    <h1>{title}</h1>
    <p>{intro}</p>
  </div>
</section>
<section class="section legal-section">
  <div class="container legal-copy"><slot /></div>
</section>
